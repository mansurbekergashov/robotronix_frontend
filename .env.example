# Frontend jamoasi uchun — ushbu faylni .env ga ko'chiring
# Ishlatish: cp .env.example .env && docker-compose up

# Backend URL — Vite dev serveri /api, /uploads, /ws so'rovlarini shu yerga yo'naltiradi
# Docker orqali ishlasa shart emas (nginx backend:8080 ga o'zi yo'naltiradi)
BACKEND_URL=http://localhost:8080
