# User Dashboard — no build step, served as static files via nginx
# This file documents the Docker environment variable for backend proxy target.
# Used only when building/running via docker-compose.frontend.yml.

# Not needed for local dev — user-master uses relative /api paths when served by nginx,
# which proxies to the backend container named "backend" on robotronix-network.
BACKEND_URL=http://robotronix-backend:8080
BACKEND_WS_URL=http://robotronix-backend:8080