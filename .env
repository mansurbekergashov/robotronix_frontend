# Frontend Docker Compose uchun sozlamalar
# Nusxalash: cp .env.example .env

# --- Variant 1: Server backendi bilan ishlash (default, tavsiya) ---
BACKEND_URL=http://robotronix-backend:8080
BACKEND_WS_URL=http://robotronix-backend:8080

# --- Variant 2: Lokal backend bilan ishlash ---
# (cd ../backend && docker-compose up -d) dan so'ng:
# BACKEND_URL=http://backend:8080
# BACKEND_WS_URL=ws://backend:8080
